# Copy to .env and edit. Loaded by pydantic-settings via src/finqa_bot/config.py.

# ---- vLLM OpenAI-compatible endpoint ------------------------------------------
# In Colab this is typically http://127.0.0.1:8000/v1 (server started by setup.sh).
# In production, point at your vLLM service URL.
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=EMPTY

# Served model alias - must match --served-model-name in the vllm serve command.
# Both t4.yaml and l4.yaml register the generator under the alias "generator",
# NOT the HuggingFace model ID. Do not set this to "Qwen/Qwen3-8B-AWQ" or
# "Qwen/Qwen3-14B-AWQ"; use the short alias below.
LLM_MODEL=generator
LLM_SPECIALIST_MODEL=rLLM/rLLM-FinQA-4B
LLM_ROUTER_MODEL=Qwen/Qwen3-1.7B

# ---- Retrieval ----------------------------------------------------------------
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RETRIEVAL_K=8
RERANK_K=4

# ---- Runtime ------------------------------------------------------------------
FINQA_LOG_LEVEL=INFO
FINQA_DATA_DIR=./data
FINQA_RUNS_DIR=./runs
FINQA_CHECKPOINT_DB=./data/checkpoints/graph.sqlite
FINQA_GPU_CONFIG=configs/t4.yaml
FINQA_EVAL_CONFIG=configs/eval.yaml
FINQA_API_HOST=0.0.0.0
FINQA_API_PORT=8001
FINQA_GRADIO_PORT=7860

# ---- Optional: OpenAI baseline (for ablation only) ----------------------------
# Leave blank to skip the OpenAI baseline in ablations.
OPENAI_API_KEY=
OPENAI_BASELINE_MODEL=gpt-4o-mini

# ---- Optional: LangSmith tracing (documentation, not required) ----------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=finqa-bot
LANGCHAIN_API_KEY=

# ---- HF ----------------------------------------------------------------------
HF_HOME=./data/hf
HUGGINGFACE_HUB_TOKEN=
