{
  "title": "FinQA Bot",
  "uid": "finqa-bot",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "annotations": {"list": []},
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Questions per minute",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(finqa_questions_total[1m]) * 60", "legendFormat": "qpm"}
      ]
    },
    {
      "id": 2,
      "title": "End-to-end latency (seconds)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(finqa_graph_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(finqa_graph_latency_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(finqa_graph_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 3,
      "title": "Refusal rate",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "finqa_refusal_rate_rolling"}
      ]
    },
    {
      "id": 4,
      "title": "Retrieval recall (rolling)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "finqa_retrieval_recall_rolling"}
      ]
    },
    {
      "id": 5,
      "title": "Input drift PSI",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "finqa_input_psi"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.2}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Ungrounded programs",
      "type": "timeseries",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "rate(finqa_ungrounded_programs_total[5m])", "legendFormat": "ungrounded/s"}
      ]
    },
    {
      "id": 7,
      "title": "Router mix",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (route) (rate(finqa_routing_total[10m]))", "legendFormat": "{{route}}"}
      ]
    },
    {
      "id": 8,
      "title": "vLLM KV-cache usage",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {"expr": "vllm:gpu_cache_usage_perc", "legendFormat": "kv-cache-%"},
        {"expr": "rate(vllm:prefix_cache_hits_total[5m]) / clamp_min(rate(vllm:prefix_cache_queries_total[5m]), 1e-9)", "legendFormat": "prefix-hit-rate"}
      ]
    },
    {
      "id": 9,
      "title": "Consistency agreement histogram",
      "type": "heatmap",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum(rate(finqa_consistency_agreement_bucket[10m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}"}
      ]
    }
  ]
}
